---
import { sql } from '../../lib/db';

const { slug } = Astro.params;

// Test if we can even get here
const testData = {
  received_slug: slug,
  timestamp: new Date().toISOString(),
  db_test: null
};

try {
  const result = await sql`SELECT COUNT(*) as count FROM companies WHERE slug = ${slug}`;
  testData.db_test = {
    success: true,
    count: result[0]?.count || 0
  };
} catch (error) {
  testData.db_test = {
    success: false,
    error: String(error)
  };
}

// Return JSON
return new Response(JSON.stringify(testData, null, 2), {
  status: 200,
  headers: {
    'Content-Type': 'application/json'
  }
});
---
