---
import { sql } from '../lib/db';
import SEO from '../components/SEO.astro';
import Schema from '../components/Schema.astro';

// Fetch homepage content
const homepageContent = await sql`
  SELECT
    section_type,
    title,
    subtitle,
    content
  FROM homepage_content
  WHERE site = 'chief-of-staff'
    AND is_active = true
  ORDER BY section_order ASC
`;

// Fetch companies for the directory
const companies = await sql`
  SELECT
    id,
    name,
    slug,
    description,
    headquarters,
    logo_url,
    specializations,
    global_rank
  FROM companies
  WHERE app = 'chief-of-staff'
    AND status = 'published'
  ORDER BY
    CASE WHEN global_rank IS NOT NULL THEN 0 ELSE 1 END,
    global_rank ASC NULLS LAST,
    name ASC
  LIMIT 10
`;

// Fetch articles with images - supporting both JSONB column and legacy tables
const articles = await sql`
  SELECT
    a.id,
    a.title,
    a.excerpt,
    a.slug,
    a.published_at,
    a.created_at,
    a.article_angle,
    a.images,
    (
      SELECT json_build_object('url', i.cloudinary_url, 'alt', aiu.alt_text)
      FROM article_image_usage aiu
      JOIN images i ON i.id = aiu.image_id
      WHERE aiu.article_id = a.id AND aiu.role = 'featured'
      LIMIT 1
    ) as featured_image_legacy
  FROM articles a
  WHERE a.app = 'chief-of-staff'
    AND a.status = 'published'
  ORDER BY a.published_at DESC NULLS LAST, a.created_at DESC
  LIMIT 6
`;

const sections = {
  hero: homepageContent.find((s: any) => s.section_type === 'hero'),
  intro: homepageContent.find((s: any) => s.section_type === 'intro'),
  role: homepageContent.find((s: any) => s.section_type === 'role'),
  topAgents: homepageContent.find((s: any) => s.section_type === 'top_agents'),
  howItWorks: homepageContent.find((s: any) => s.section_type === 'how_it_works'),
  feeStructures: homepageContent.find((s: any) => s.section_type === 'fee_structures'),
  selection: homepageContent.find((s: any) => s.section_type === 'selection'),
  whyUse: homepageContent.find((s: any) => s.section_type === 'why_use'),
  trends: homepageContent.find((s: any) => s.section_type === 'trends'),
  faq: homepageContent.find((s: any) => s.section_type === 'faq')
};
---

<!DOCTYPE html>
<html lang="en">
<head>
  <SEO />
  <Schema type="homepage" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/animations.css" />
  <style>
    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    }

    /* Critical animations - inline for immediate load */
    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(20px); }
      to { opacity: 1; transform: translateY(0); }
    }

    @keyframes fadeInUp {
      from { opacity: 0; transform: translateY(40px); }
      to { opacity: 1; transform: translateY(0); }
    }

    @keyframes gradientShift {
      0% { background-position: 0% 50%; }
      50% { background-position: 100% 50%; }
      100% { background-position: 0% 50%; }
    }

    .gradient-animate {
      background-size: 200% 200%;
      animation: gradientShift 15s ease infinite;
    }

    .animate-fade-in {
      animation: fadeIn 0.8s ease-out forwards;
    }

    .animate-fade-in-up {
      animation: fadeInUp 1s ease-out forwards;
    }

    .animation-delay-100 { animation-delay: 0.1s; }
    .animation-delay-200 { animation-delay: 0.2s; }
    .animation-delay-300 { animation-delay: 0.3s; }
    .animation-delay-500 { animation-delay: 0.5s; }

    .hover-lift {
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .hover-lift:hover {
      transform: translateY(-8px);
      box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);
    }

    .text-gradient {
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .fade-in-scroll {
      opacity: 0;
      transform: translateY(30px);
      transition: opacity 0.8s ease-out, transform 0.8s ease-out;
    }

    .fade-in-scroll.visible {
      opacity: 1;
      transform: translateY(0);
    }

    html {
      scroll-behavior: smooth;
    }
  </style>
</head>
<body class="bg-gradient-to-br from-slate-50 via-blue-50 to-indigo-50">
  <!-- Navigation -->
  <nav class="fixed top-0 w-full bg-white/80 backdrop-blur-md z-50 border-b border-gray-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between items-center h-20">
        <div class="flex items-center">
          <h1 class="text-2xl font-black bg-gradient-to-r from-blue-600 to-indigo-600 bg-clip-text text-transparent">
            Chief of Staff
          </h1>
        </div>
        <div class="flex items-center space-x-8">
          <a href="/" class="text-sm font-semibold text-blue-600 hover:text-blue-700 transition-colors">Home</a>
          <a href="/articles" class="text-sm font-semibold text-gray-700 hover:text-blue-600 transition-colors">Articles</a>
          <a href="/companies" class="px-6 py-2.5 bg-gradient-to-r from-blue-600 to-indigo-600 text-white rounded-full font-semibold hover:shadow-lg hover:scale-105 transition-all duration-300">
            Companies
          </a>
        </div>
      </div>
    </div>
  </nav>

  <!-- Hero Section -->
  {sections.hero && (
    <section class="relative min-h-screen flex items-center justify-center overflow-hidden pt-20">
      <!-- Animated background gradient -->
      <div class="absolute inset-0 bg-gradient-to-br from-blue-600 via-indigo-600 to-purple-700 gradient-animate"></div>

      <!-- Overlay -->
      <div class="absolute inset-0 bg-black/20"></div>

      <!-- Geometric patterns -->
      <div class="absolute inset-0 opacity-10">
        <div class="absolute top-20 left-10 w-72 h-72 bg-white rounded-full mix-blend-overlay filter blur-3xl animate-pulse"></div>
        <div class="absolute bottom-20 right-10 w-96 h-96 bg-blue-300 rounded-full mix-blend-overlay filter blur-3xl animate-pulse animation-delay-300"></div>
      </div>

      <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-32">
        <div class="text-center max-w-5xl mx-auto">
          <!-- Badge -->
          <div class="inline-flex items-center px-4 py-2 rounded-full bg-white/10 backdrop-blur-sm border border-white/20 mb-8 animate-fade-in">
            <span class="w-2 h-2 bg-green-400 rounded-full mr-3 animate-pulse"></span>
            <span class="text-white/90 text-sm font-medium">The Definitive Industry Resource</span>
          </div>

          <h2 class="text-5xl md:text-7xl lg:text-8xl font-black mb-8 leading-tight animate-fade-in-up animation-delay-100">
            <span class="text-white drop-shadow-2xl">
              {sections.hero.title}
            </span>
          </h2>

          <p class="text-xl md:text-2xl lg:text-3xl text-white/90 mb-12 leading-relaxed font-light max-w-4xl mx-auto animate-fade-in-up animation-delay-200">
            {sections.hero.subtitle}
          </p>

          {sections.hero.content?.cta_text && (
            <div class="flex flex-col sm:flex-row gap-4 justify-center items-center animate-fade-in-up animation-delay-300">
              <a href="/companies" class="group px-8 py-4 bg-white text-blue-600 rounded-full font-bold text-lg hover:shadow-2xl hover:scale-105 transition-all duration-300 inline-flex items-center">
                {sections.hero.content.cta_text}
                <svg class="w-5 h-5 ml-2 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
                </svg>
              </a>
              <a href="/articles" class="px-8 py-4 bg-white/10 backdrop-blur-sm text-white rounded-full font-bold text-lg border-2 border-white/30 hover:bg-white/20 transition-all duration-300">
                Read Articles
              </a>
            </div>
          )}

          <!-- Stats -->
          <div class="grid grid-cols-3 gap-8 mt-20 max-w-3xl mx-auto animate-fade-in animation-delay-500">
            <div class="text-center">
              <div class="text-4xl md:text-5xl font-black text-white mb-2">2025</div>
              <div class="text-white/70 text-sm font-medium">Latest Data</div>
            </div>
            <div class="text-center border-x border-white/20">
              <div class="text-4xl md:text-5xl font-black text-white mb-2">Top</div>
              <div class="text-white/70 text-sm font-medium">Agencies Ranked</div>
            </div>
            <div class="text-center">
              <div class="text-4xl md:text-5xl font-black text-white mb-2">100%</div>
              <div class="text-white/70 text-sm font-medium">Comprehensive</div>
            </div>
          </div>
        </div>
      </div>

      <!-- Scroll indicator -->
      <div class="absolute bottom-8 left-1/2 transform -translate-x-1/2 animate-bounce">
        <svg class="w-6 h-6 text-white/60" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/>
        </svg>
      </div>
    </section>
  )}

  <!-- Intro Section -->
  {sections.intro && (
    <section class="py-16 bg-white">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-3xl font-bold text-gray-900 mb-6">{sections.intro.title}</h2>
        <div class="prose prose-lg max-w-none space-y-4">
          {sections.intro.content?.paragraphs?.map((para: any) => (
            <p class="text-gray-700 leading-relaxed">{para.text}</p>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Role Section -->
  {sections.role && (
    <section class="py-16 bg-gray-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <h2 class="text-3xl font-bold text-gray-900 mb-4">{sections.role.title}</h2>
          {sections.role.subtitle && <p class="text-xl text-gray-600">{sections.role.subtitle}</p>}
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {sections.role.content?.items?.map((item: any) => (
            <div class="bg-white p-6 rounded-lg shadow-sm border border-gray-200 hover:shadow-md transition-shadow">
              <h3 class="text-lg font-bold text-gray-900 mb-3">{item.title}</h3>
              <p class="text-gray-600 text-sm leading-relaxed">{item.description}</p>
            </div>
          ))}
        </div>
        {sections.role.content?.summary && (
          <div class="mt-8 bg-blue-50 p-6 rounded-lg">
            <p class="text-gray-700 leading-relaxed">{sections.role.content.summary}</p>
          </div>
        )}
      </div>
    </section>
  )}

  <!-- Top Recruitment Agencies Section -->
  {companies.length > 0 && (
    <section class="py-24 bg-white relative overflow-hidden">
      <!-- Background decoration -->
      <div class="absolute top-0 right-0 w-96 h-96 bg-blue-100 rounded-full filter blur-3xl opacity-20 -mr-48 -mt-48"></div>
      <div class="absolute bottom-0 left-0 w-96 h-96 bg-indigo-100 rounded-full filter blur-3xl opacity-20 -ml-48 -mb-48"></div>

      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative">
        <div class="text-center mb-16 fade-in-scroll">
          <span class="inline-block px-4 py-2 bg-blue-50 text-blue-600 rounded-full text-sm font-semibold mb-4">
            Top Ranked Agencies
          </span>
          <h2 class="text-4xl md:text-5xl font-black text-gray-900 mb-4">
            Leading Recruitment <span class="text-gradient">Agencies</span>
          </h2>
          <p class="text-xl text-gray-600 max-w-3xl mx-auto">
            Top agencies specializing in Chief of Staff and Executive Assistant recruitment
          </p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {companies.map((company: any, index: number) => (
            <a
              href={`/companies/${company.slug}`}
              class="group relative bg-white rounded-2xl border border-gray-100 hover:border-blue-200 p-8 block hover-lift fade-in-scroll"
              style={`animation-delay: ${index * 0.1}s`}
            >
              <!-- Gradient accent -->
              <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-blue-500 to-indigo-500 rounded-t-2xl opacity-0 group-hover:opacity-100 transition-opacity"></div>

              {/* Company Logo */}
              {company.logo_url && (
                <div class="mb-6 h-12 flex items-center">
                  <img
                    src={company.logo_url}
                    alt={`${company.name} logo`}
                    class="h-10 w-auto filter grayscale group-hover:grayscale-0 transition-all duration-300"
                  />
                </div>
              )}

              {/* Company Name & Rank */}
              <div class="flex items-start justify-between mb-4">
                <h3 class="text-2xl font-black text-gray-900 flex-1 group-hover:text-blue-600 transition-colors">
                  {company.name}
                </h3>
                {company.global_rank && (
                  <span class="ml-3 inline-flex items-center px-3 py-1 rounded-full text-xs font-bold bg-gradient-to-r from-blue-500 to-indigo-500 text-white shadow-sm">
                    #{company.global_rank}
                  </span>
                )}
              </div>

              {/* Location */}
              {company.headquarters && company.headquarters !== 'Unavailable from provided context' && (
                <div class="flex items-center text-sm text-gray-500 mb-4">
                  <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                  </svg>
                  {company.headquarters}
                </div>
              )}

              {/* Description */}
              {company.description && (
                <p class="text-gray-600 mb-6 line-clamp-3 leading-relaxed">
                  {company.description}
                </p>
              )}

              {/* Specializations */}
              {company.specializations && company.specializations.length > 0 && (
                <div class="flex flex-wrap gap-2 pt-4 border-t border-gray-100">
                  {company.specializations.slice(0, 3).map((spec: string) => (
                    <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold bg-blue-50 text-blue-700 group-hover:bg-blue-100 transition-colors">
                      {spec}
                    </span>
                  ))}
                  {company.specializations.length > 3 && (
                    <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold text-gray-500">
                      +{company.specializations.length - 3}
                    </span>
                  )}
                </div>
              )}

              <!-- Arrow icon -->
              <div class="absolute bottom-8 right-8 w-8 h-8 bg-blue-50 rounded-full flex items-center justify-center opacity-0 group-hover:opacity-100 transform translate-x-2 group-hover:translate-x-0 transition-all">
                <svg class="w-4 h-4 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                </svg>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- How It Works Section -->
  {sections.howItWorks && (
    <section class="py-16 bg-gray-50">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <h2 class="text-3xl font-bold text-gray-900 mb-4">{sections.howItWorks.title}</h2>
          {sections.howItWorks.subtitle && <p class="text-xl text-gray-600">{sections.howItWorks.subtitle}</p>}
        </div>
        <div class="space-y-6">
          {sections.howItWorks.content?.phases?.map((phase: any, index: number) => (
            <div class="bg-white p-6 rounded-lg shadow-sm border-l-4 border-blue-600">
              <div class="flex items-start gap-4">
                <div class="flex-shrink-0 w-10 h-10 bg-blue-600 text-white rounded-full flex items-center justify-center font-bold">
                  {index + 1}
                </div>
                <div class="flex-1">
                  <div class="flex items-center justify-between mb-2">
                    <h3 class="text-lg font-bold text-gray-900">{phase.name}</h3>
                    <span class="text-sm text-gray-500">{phase.duration}</span>
                  </div>
                  <p class="text-gray-700 leading-relaxed">{phase.description}</p>
                </div>
              </div>
            </div>
          ))}
        </div>
        {sections.howItWorks.content?.summary && (
          <div class="mt-8 bg-blue-50 p-6 rounded-lg">
            <p class="text-gray-700 font-semibold">{sections.howItWorks.content.summary}</p>
          </div>
        )}
      </div>
    </section>
  )}

  <!-- FAQ Section -->
  {sections.faq && (
    <section class="py-16 bg-white">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <h2 class="text-3xl font-bold text-gray-900 mb-4">{sections.faq.title}</h2>
          {sections.faq.subtitle && <p class="text-xl text-gray-600">{sections.faq.subtitle}</p>}
        </div>
        <div class="space-y-6">
          {sections.faq.content?.questions?.map((item: any) => (
            <div class="bg-gray-50 p-6 rounded-lg">
              <h3 class="text-lg font-bold text-gray-900 mb-3">{item.question}</h3>
              <p class="text-gray-700 leading-relaxed">{item.answer}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Latest Articles -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-gray-900 mb-8">Latest Articles</h2>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {articles.map((article: any) => (
          <article class="bg-white rounded-lg shadow-md overflow-hidden hover:shadow-lg transition-shadow">
            {(article.images?.featured || article.featured_image_legacy?.url) && (
              <img src={article.images?.featured || article.featured_image_legacy.url} alt={article.featured_image_legacy?.alt || article.title} class="w-full h-48 object-cover" />
            )}
            <div class="p-6">
              {article.article_angle && (
                <span class="inline-block bg-blue-100 text-blue-800 text-xs font-semibold px-2.5 py-0.5 rounded mb-3">
                  {article.article_angle}
                </span>
              )}
              <h3 class="text-xl font-bold text-gray-900 mb-3 line-clamp-2">
                <a href={`/${article.slug}`} class="hover:text-blue-600">
                  {article.title}
                </a>
              </h3>
              {article.excerpt && (
                <p class="text-gray-600 mb-4 line-clamp-3">
                  {article.excerpt}
                </p>
              )}
              <div class="flex items-center justify-between text-sm text-gray-500">
                <time datetime={article.published_at || article.created_at}>
                  {new Date(article.published_at || article.created_at).toLocaleDateString('en-US', {
                    year: 'numeric',
                    month: 'long',
                    day: 'numeric'
                  })}
                </time>
                <a href={`/${article.slug}`} class="text-blue-600 hover:text-blue-800 font-medium">
                  Read more →
                </a>
              </div>
            </div>
          </article>
        ))}
      </div>

      {articles.length === 0 && (
        <div class="text-center py-12">
          <p class="text-gray-600 text-lg">No articles published yet. Check back soon!</p>
        </div>
      )}
    </div>
  </section>

  <!-- Footer -->
  <footer class="bg-gray-900 text-white py-12 mt-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-8">
        <div>
          <h3 class="text-lg font-bold mb-4">Chief of Staff</h3>
          <p class="text-gray-400 text-sm">Your source for Chief of Staff and Executive Assistant recruitment insights and industry news.</p>
        </div>
        <div>
          <h3 class="text-lg font-bold mb-4">Navigate</h3>
          <ul class="space-y-2 text-sm">
            <li><a href="/" class="text-gray-400 hover:text-white">Home</a></li>
            <li><a href="/articles" class="text-gray-400 hover:text-white">Articles</a></li>
            <li><a href="/companies" class="text-gray-400 hover:text-white">Companies Directory</a></li>
          </ul>
        </div>
        <div>
          <h3 class="text-lg font-bold mb-4">Resources</h3>
          <ul class="space-y-2 text-sm">
            <li><a href="/companies" class="text-gray-400 hover:text-white">Top Recruitment Agencies</a></li>
            <li><a href="/articles" class="text-gray-400 hover:text-white">Industry News</a></li>
          </ul>
        </div>
      </div>
      <div class="border-t border-gray-800 pt-8 text-center">
        <p class="text-gray-400 text-sm">© {new Date().getFullYear()} Chief of Staff. All rights reserved.</p>
      </div>
    </div>
  </footer>

  <!-- Scroll animations script -->
  <script>
    // Intersection Observer for scroll animations
    const observerOptions = {
      root: null,
      rootMargin: '0px',
      threshold: 0.1
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
        }
      });
    }, observerOptions);

    // Observe all elements with fade-in-scroll class
    document.addEventListener('DOMContentLoaded', () => {
      const fadeElements = document.querySelectorAll('.fade-in-scroll');
      fadeElements.forEach(el => observer.observe(el));
    });
  </script>
</body>
</html>
