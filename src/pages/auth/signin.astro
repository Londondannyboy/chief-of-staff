---
// Sign in page - redirects to Stack Auth's hosted signin
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sign In - Chief of Staff Quest</title>
    <style>
        body {
            font-family: system-ui, -apple-system, sans-serif;
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            margin: 0;
            background: #f5f5f5;
        }
        .container {
            text-align: center;
            padding: 2rem;
            background: white;
            border-radius: 8px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.1);
            max-width: 400px;
        }
        button {
            background: #0070f3;
            color: white;
            border: none;
            padding: 12px 24px;
            border-radius: 6px;
            font-size: 16px;
            cursor: pointer;
            margin-top: 1rem;
        }
        button:hover {
            background: #0051cc;
        }
    </style>
    <script src="https://cdn.jsdelivr.net/npm/@stackframe/stack@latest/dist/index.global.js"></script>
    <script>
        window.signIn = () => {
            console.log('Sign in clicked');
            const projectId = "5ef873fa-5690-460a-bc2c-b29802508691";
            const returnUrl = encodeURIComponent(window.location.origin + "/auth/callback");
            const signInUrl = `https://app.stack-auth.com/handler/sign-in?project_id=${projectId}&after_auth_return_to=${returnUrl}`;
            console.log('Redirecting to:', signInUrl);
            window.location.href = signInUrl;
        };
    </script>
</head>
<body>
    <div class="container">
        <h1>Sign In</h1>
        <p>Sign in to Chief of Staff Quest</p>
        <button onclick="signIn()">Sign In with Stack Auth</button>
    </div>
</body>
</html>
