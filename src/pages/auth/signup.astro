---
// Sign up page - redirects to Stack Auth's hosted signup
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sign Up - Chief of Staff Quest</title>
    <style>
        body {
            font-family: system-ui, -apple-system, sans-serif;
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            margin: 0;
            background: #f5f5f5;
        }
        .container {
            text-align: center;
            padding: 2rem;
            background: white;
            border-radius: 8px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.1);
            max-width: 400px;
        }
        button {
            background: #0070f3;
            color: white;
            border: none;
            padding: 12px 24px;
            border-radius: 6px;
            font-size: 16px;
            cursor: pointer;
            margin-top: 1rem;
        }
        button:hover {
            background: #0051cc;
        }
        a {
            color: #0070f3;
            text-decoration: none;
            margin-top: 1rem;
            display: inline-block;
        }
    </style>
    <script src="https://cdn.jsdelivr.net/npm/@stackframe/stack@latest/dist/index.global.js"></script>
    <script>
        window.signUp = () => {
            console.log('Sign up clicked');
            const projectId = "5ef873fa-5690-460a-bc2c-b29802508691";
            const returnUrl = encodeURIComponent(window.location.origin + "/auth/callback");
            const signUpUrl = `https://app.stack-auth.com/handler/sign-up?project_id=${projectId}&after_auth_return_to=${returnUrl}`;
            console.log('Redirecting to:', signUpUrl);
            window.location.href = signUpUrl;
        };
    </script>
</head>
<body>
    <div class="container">
        <h1>Sign Up</h1>
        <p>Create your Chief of Staff Quest account</p>
        <button onclick="signUp()">Sign Up with Stack Auth</button>
        <br>
        <a href="/auth/signin">Already have an account? Sign in</a>
    </div>
</body>
</html>
